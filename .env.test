# E2E Test Configuration
# Copy these values from laemp.sh installation output

# Moodle URL (must match compose.yml port mapping)
MOODLE_URL=https://moodle.127.0.0.1.sslip.io

# Admin credentials (generated during installation)
MOODLE_ADMIN_USERNAME=admin
MOODLE_ADMIN_PASSWORD=CHANGE_ME_FROM_INSTALL_OUTPUT
MOODLE_ADMIN_EMAIL=admin@moodle.127.0.0.1.sslip.io

# Test configuration
MOODLE_SITE_NAME=moodle.127.0.0.1.sslip.io
